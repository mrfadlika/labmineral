function canAccessPeralatan() {
    return isAdmin() || isAnalis() || isSupervisor();
}

function canEditPeralatan() {
    return isAdmin() || isAnalis() || isSupervisor();
}

/**
 * Laporan
 * - Admin: full akses
 * - Analis: tidak ada akses
 * - Supervisor: full akses
 */
function canAccessLaporan() {
